<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>AstroPanoStudio</AssemblyName>
    <RootNamespace>AstroPanoStudio</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="..\..\index.html" Link="index.html" />
    <EmbeddedResource Include="..\..\app.js" Link="app.js" />
    <EmbeddedResource Include="..\..\styles.css" Link="styles.css" />
    <EmbeddedResource Include="..\..\stack-worker.js" Link="stack-worker.js" />
  </ItemGroup>
</Project>
